# --- Local Docker (default) — run: docker compose up -d ---
DATABASE_URL=jdbc:postgresql://localhost:5433/content_hub
DATABASE_USERNAME=contenthub
DATABASE_PASSWORD=contenthub

# --- Supabase (cloud) — see docs/SUPABASE.md ---
# DATABASE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_supabase_db_password

JWT_SECRET=replace-with-a-long-random-string-min-32-characters
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Google Cloud Console → OAuth 2.0 Client
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
