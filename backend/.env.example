# Supabase: Project Settings → Database → Connection string (URI)
# Use the "Session pooler" or direct connection with sslmode=require
DATABASE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_supabase_db_password

JWT_SECRET=replace-with-a-long-random-string-min-32-characters
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Google Cloud Console → OAuth 2.0 Client
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
