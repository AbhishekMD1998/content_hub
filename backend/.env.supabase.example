# Copy to backend/.env when using Supabase instead of local Docker Postgres
#
# Supabase → Project Settings → Database → Connection string → URI
# Convert: postgresql://postgres.[ref]:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres
# To JDBC (use port 5432 direct / session mode for Flyway + JPA):
#
# DATABASE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_database_password

DATABASE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_supabase_db_password

JWT_SECRET=generate-with-openssl-rand-base64-48
JWT_EXPIRATION_MS=86400000

FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
